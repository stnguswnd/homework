DATABASE_URL="postgresql://user:password@localhost:5432/homework"
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

NEXT_PUBLIC_SUPABASE_IMAGE_BUCKET="homework-image"
NEXT_PUBLIC_SUPABASE_AUDIO_BUCKET="homework-audio"

# Server-only AI writing feedback config. Do not expose this as NEXT_PUBLIC_*.
OPENAI_API_KEY="replace-with-openai-api-key"
OPENAI_WRITING_MODEL="gpt-4.1-mini"

# Demo data is skipped in production unless this is explicitly enabled.
ALLOW_DEMO_SEED="false"
